{
  "$schema": "https://turborepo.dev/schema.v2.json",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "PORT",
        "GAME_SERVER_PORT",
        "LLM_PROVIDER",
        "GOOGLE_GENERATIVE_AI_API_KEY",
        "OPENROUTER_API_KEY",
        "SOLANA_RPC_URL",
        "AUTHORITY_KEYPAIR_PATH",
        "AUTHORITY_PRIVATE_KEY",
        "EPHEMERAL_PROVIDER_ENDPOINT",
        "EPHEMERAL_WS_ENDPOINT",
        "AUTO_MATCH_ENABLED",
        "AUTO_MATCH_INTERVAL_MS"
      ]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "PORT",
        "GAME_SERVER_PORT",
        "LLM_PROVIDER",
        "GOOGLE_GENERATIVE_AI_API_KEY",
        "OPENROUTER_API_KEY",
        "SOLANA_RPC_URL",
        "AUTHORITY_KEYPAIR_PATH",
        "AUTHORITY_PRIVATE_KEY",
        "EPHEMERAL_PROVIDER_ENDPOINT",
        "EPHEMERAL_WS_ENDPOINT",
        "AUTO_MATCH_ENABLED",
        "AUTO_MATCH_INTERVAL_MS"
      ]
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "generate": {
      "cache": false
    }
  }
}
